{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://consiliency.io/contracts/lease-event.schema.json",
  "title": "Consiliency lease event",
  "description": "One entry in the append-only lease-event stream. The current-lease VIEW is a projection of this stream; the lease store is the sole source of truth for lease state.",
  "type": "object",
  "required": ["schema", "event", "lease_id", "holder", "at"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "consiliency.lease_event.v1"},
    "event": {"enum": ["acquire", "renew", "release", "expire"]},
    "lease_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.:-]*$"},
    "holder": {"type": "string", "minLength": 1},
    "at": {"type": "string", "minLength": 1},
    "lease": {"$ref": "https://consiliency.io/contracts/lease.schema.json"}
  }
}
